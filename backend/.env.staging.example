# Copy to .env.staging on the VPS and replace secrets.
# From backend/: docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build

ENVIRONMENT=staging

# Ports (host) — must match docker-compose.staging.yml defaults
BACKEND_PORT=8083
PG_PORT=5436
MINIO_API_PORT=9006
MINIO_CONSOLE_PORT=9007

# Database (staging DB name suffix _staging)
DB_USER=masjid_user
DB_PASSWORD=change-me-staging-db-password
DB_NAME=masjid_db_staging

DATABASE_URL=postgres://masjid_user:change-me-staging-db-password@postgres:5432/masjid_db_staging?sslmode=disable

JWT_SECRET=change-me-min-32-chars-staging-jwt-secret

# Staging frontend (CORS / redirects)
FRONTEND_URL=https://staging.masjidbaiturrahimsb.org

# MinIO (internal hostname is the service name)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin-staging
MINIO_SECRET_KEY=change-me-minio-staging-secret
MINIO_BUCKET=masjid-assets-staging
# Public base URL for object links (adjust after Nginx/SSL for MinIO if exposed)
MINIO_OBJECT_URL=http://127.0.0.1:9006

# Finance report (Excel) — optional overrides
FINANCE_REPORT_BANK_LINE=Rekening Bank: (staging)
EXCEL_SIGNER_LEFT_NAME=H. MUHAMMAD YAHYA ZUBIR
EXCEL_SIGNER_RIGHT_NAME=MOHAMAD DJOKO SANTOSO

# Sentry — staging DSN (leave empty to disable)
SENTRY_DSN=
