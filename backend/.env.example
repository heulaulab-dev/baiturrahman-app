# Server Configuration
PORT=8080
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgres://USER:PASSWORD@localhost:DB_PORT/DB_NAME?sslmode=disable

DB_USER=USER
DB_PASSWORD=PASSWORD
DB_NAME=DATABASE
DB_PORT=5432


# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-characters-required

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# MinIO (S3-compatible storage for admin image uploads)
# Docker Compose: use service hostname; local MinIO on host: http://localhost:9000
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=uploads
MINIO_OBJECT_URL=http://minio:9000
