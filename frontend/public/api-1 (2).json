{
  "openapi": "3.1.0",
  "info": {
    "title": "MuslimPro API",
    "description": "Muslim Pro Scrapper cache based API 🕌",
    "license": {
      "name": "MIT License",
      "url": "https://github.com/lleans/Muslim-Pro-Scrapper/raw/main/LICENSE"
    },
    "version": "2.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "handlers"
        ],
        "operationId": "get_location_based",
        "responses": {
          "307": {
            "description": "Temporary redirect to a location-based route derived from the requester IP"
          },
          "404": {
            "description": "IP lookup failed or location could not be resolved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponse"
                },
                "example": {
                  "data": null,
                  "message": "IP lookup failed",
                  "status": 404
                }
              }
            }
          },
          "500": {
            "description": "Unexpected internal failure while resolving the requester IP",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponse"
                },
                "example": {
                  "data": null,
                  "message": "Something went wrong!!",
                  "status": 500
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "handlers"
        ],
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "All health checks passed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "detail": {
                    "ipLookup": "ok",
                    "redis": "ok",
                    "system": "ok",
                    "upstream": "ok"
                  },
                  "healthy": true
                }
              }
            }
          },
          "503": {
            "description": "One or more health checks failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "detail": {
                    "ipLookup": "ok",
                    "redis": "error",
                    "system": "ok",
                    "upstream": "ok"
                  },
                  "healthy": false
                }
              }
            }
          }
        }
      }
    },
    "/{query}": {
      "get": {
        "tags": [
          "handlers"
        ],
        "operationId": "main_app",
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "description": "City/country name",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "jakarta"
          },
          {
            "name": "calcMethod",
            "in": "query",
            "description": "Calculation method. Supported values:\n- DEFAULT\n- ALGERIA\n- CUSTOMANGLE\n- CUSTOM_ANGLES\n- DIYANET\n- EGYPT\n- EGYPTBIS\n- FIXEDISHA\n- FIXED_ISHA_ANGLE_INTERVAL\n- FR15\n- FRANCE_ANGLE_15_DEG\n- FR18\n- FRANCE_ANGLE_18_DEG\n- KARACHI\n- JAKIM\n- UIPTL\n- MUIS\n- MWL\n- UOIF\n- MUSULMANS_DE_FRANCE\n- FRANCE_UOIF_ANGLE_12_DEG\n- ISNA\n- NORTH_AMERICA_ISNA\n- JAFARI\n- SHIA_ITHNA_ASHARI_JAFARI\n- KEMENAG\n- SIHAT_KEMENAG_KEMENTERIAN_AGAMA_RI\n- TUNISIA\n- TUNISIAN_MINISTRY_OF_RELIGIOUS_AFFAIRS\n- AWQAFUAE\n- UAE_GENERAL_AUTHORITY_OF_ISLAMIC_AFFAIRS_AND_ENDOWMENTS\n- MAKKAH\n- UMM_AL_QURA_MAKKAH\n- TEHRAN\n- UNIVERSITY_OF_TEHRAN\n- BASQUE\n- BASQUE_COUNTRY\n- FEDERATION_OF_ISLAMIC_ASSOCIATIONS_IN_BASQUE_COUNTRY\n\nHere some reference for calculation method<br />\n- [Prayer Time Calculation - PrayTimes.org 📚](http://praytimes.org/calculation)\n- [California IslamiC University 🎓](https://www.calislamic.com/fifteen-or-eighteen-degrees-calculating-prayer-and-fasting-times-in-islam/)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "KEMENAG"
          }
        ],
        "responses": {
          "200": {
            "description": "Prayer times data fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponse"
                },
                "example": {
                  "data": {
                    "calculationMethod": "KEMENAG",
                    "location": "Jakarta, Indonesia",
                    "praytimes": {
                      "Fri Mar 20": {
                        "Asr": "15:15",
                        "Fajr": "04:43",
                        "Isha": "19:12",
                        "Maghrib": "18:04",
                        "Zuhr": "11:58"
                      }
                    },
                    "ramadhan": {
                      "2026": {
                        "end": "March 19",
                        "start": "February 18"
                      }
                    }
                  },
                  "message": "OK",
                  "status": 200
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters, such as unsupported calculation method",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponse"
                },
                "example": {
                  "data": null,
                  "message": "Bad request: Matching calculation method not found",
                  "status": 400
                }
              }
            }
          },
          "404": {
            "description": "Location could not be resolved or upstream prayer data was not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponse"
                },
                "example": {
                  "data": null,
                  "message": "Location was not found",
                  "status": 404
                }
              }
            }
          },
          "500": {
            "description": "Unexpected internal failure, such as Redis or outbound request issues",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaseResponse"
                },
                "example": {
                  "data": null,
                  "message": "Something went wrong!!",
                  "status": 500
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "required": [
          "status",
          "message"
        ],
        "properties": {
          "data": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ModelResponse"
              }
            ]
          },
          "message": {
            "type": "string",
            "example": "OK"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "example": 200,
            "minimum": 0
          }
        },
        "example": {
          "data": {
            "calculationMethod": "KEMENAG",
            "location": "Jakarta, Indonesia",
            "praytimes": {
              "Fri Mar 20": {
                "Asr": "15:15",
                "Fajr": "04:43",
                "Isha": "19:12",
                "Maghrib": "18:04",
                "Zuhr": "11:58"
              }
            },
            "ramadhan": {
              "2026": {
                "end": "March 19",
                "start": "February 18"
              }
            }
          },
          "message": "OK",
          "status": 200
        }
      },
      "HealthDetail": {
        "type": "object",
        "required": [
          "redis",
          "upstream",
          "ipLookup",
          "system"
        ],
        "properties": {
          "ipLookup": {
            "type": "string",
            "example": "ok"
          },
          "redis": {
            "type": "string",
            "example": "ok"
          },
          "system": {
            "type": "string",
            "example": "ok"
          },
          "upstream": {
            "type": "string",
            "example": "ok"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "healthy",
          "detail"
        ],
        "properties": {
          "detail": {
            "$ref": "#/components/schemas/HealthDetail"
          },
          "healthy": {
            "type": "boolean"
          }
        },
        "example": {
          "detail": {
            "ipLookup": "ok",
            "redis": "ok",
            "system": "ok",
            "upstream": "ok"
          },
          "healthy": true
        }
      },
      "ModelResponse": {
        "type": "object",
        "required": [
          "location",
          "calculationMethod",
          "praytimes"
        ],
        "properties": {
          "calculationMethod": {
            "type": "string",
            "example": "KEMENAG"
          },
          "location": {
            "type": "string",
            "example": "Jakarta, Indonesia"
          },
          "praytimes": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/PrayerTimesResponse"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "ramadhan": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": {
              "$ref": "#/components/schemas/RamadhanResponse"
            },
            "propertyNames": {
              "type": "string"
            }
          }
        },
        "example": {
          "calculationMethod": "KEMENAG",
          "location": "Jakarta, Indonesia",
          "praytimes": {
            "Fri Mar 20": {
              "Asr": "15:15",
              "Fajr": "04:43",
              "Isha": "19:12",
              "Maghrib": "18:04",
              "Zuhr": "11:58"
            }
          },
          "ramadhan": {
            "2026": {
              "end": "March 19",
              "start": "February 18"
            }
          }
        }
      },
      "PrayerTimesResponse": {
        "type": "object",
        "required": [
          "Fajr",
          "Zuhr",
          "Asr",
          "Maghrib",
          "Isha"
        ],
        "properties": {
          "Asr": {
            "type": "string",
            "example": "15:15"
          },
          "Fajr": {
            "type": "string",
            "example": "04:43"
          },
          "Isha": {
            "type": "string",
            "example": "19:12"
          },
          "Maghrib": {
            "type": "string",
            "example": "18:04"
          },
          "Zuhr": {
            "type": "string",
            "example": "11:58"
          }
        }
      },
      "RamadhanResponse": {
        "type": "object",
        "required": [
          "start",
          "end"
        ],
        "properties": {
          "end": {
            "type": "string",
            "example": "March 19"
          },
          "start": {
            "type": "string",
            "example": "February 18"
          }
        }
      }
    }
  }
}